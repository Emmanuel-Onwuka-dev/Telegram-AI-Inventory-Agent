      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Use this to add a NEW item OR update the quantity of an EXISTING item in the inventory sheet.\n\nFor a NEW item: confirm with the user that you have item name, category, quantity, unit, reorder threshold, and price before calling this.\n\nFor an EXISTING item (user wants to add/remove stock): first use the Lookup tool to check if the item already exists and get its current quantity. If it exists, calculate the new total quantity (current quantity + or - the amount mentioned) and pass that final number here, along with the item's existing category, unit, reorder threshold, and price (do not change these unless the user explicitly asks to).\n\nAlways match on the Item field exactly as it appears in the sheet.",
        "operation": "appendOrUpdate",
        "documentId": {
          "__rl": true,
          "value": "1uTwPD-iU5dRyaNNca4aEfiIZbDsnzWW8K0KHHdr33dA",
